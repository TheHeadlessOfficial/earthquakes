conky.config = {
	alignment = 'top_left', --top_left, top_right, top_middle, bottom_left, bottom_right, bottom_middle, middle_left, middle_middle, middle_right, or none (also can be abreviated as tl, tr, tm, bl, br, bm, ml, mm, mr)
	background = true,
	border_inner_margin = 5,
	border_outer_margin = 0,
	border_width = 0,
	color0 = 'violet';
	color1 = 'add8e6',
	color2 = 'ffe595',
	color3 = 'orange',
	color4 = 'red',
	color5 = '0068c8',
	color6 = 'green',
	color7 = 'darkgrey',
 	color8 = '1e90ff',--dodgerblue
	color9 = 'yellow';
	cpu_avg_samples = 2,

--default_bar_size = 30 8
	default_color = 'white',
--default_graph_size 15 40
	default_outline_color = '#000000',
	default_shade_color = '#000000',
	double_buffer = true,
	draw_borders = false,
	draw_graph_borders = false,
	draw_outline = false,-- amplifies text if yes
	draw_shades = false,
	extra_newline = false,
	font = 'URW Gothic L:size=8',
--font = 'Roboto:size=10',
	gap_x = 410,-- l|r (1230 per progetto)
	gap_y = 10,-- u|d  (560 per progetto)
	imlib_cache_size = 0,
	maximum_width = 800,
	minimum_size = 800,
	minimum_height = 250,
	minimum_width = 500,
	net_avg_samples = 2,
	no_buffers = true,
	out_to_console = false,
	out_to_stderr = false,
	override_utf8_locale = true,
	own_window = true,
	own_window_argb_visual = true,
	own_window_argb_value = 200,
	own_window_class = 'Conky',
--own_window_class = 'Conky-semi',
--own_window_colour = '#a6a4a3',
	own_window_hints = 'undecorated,below,skip_taskbar,skip_pager',
--own_window_title = '4_Moon Teo Style',
	own_window_transparent = false,
--own_window_type = 'desktop',     --normal, desktop, dock, panel or override
	own_window_type = 'normal',
	pad_percents = 2,
	short_units = true,
	show_graph_range = true,
	show_graph_scale = true,
	stippled_borders = 5,
--text_buffer_size = 2048,
--total_run_times 0,
	update_interval = 600,
	uppercase = false,-- set to yes if you want all text to be in uppercase
	use_spacer = 'none',
	use_xft = true,
	xftalpha = 1.0,
--xftfont = Zekton:size=9,
	
}

conky.text = [[
${font After Disaster:size=12}${color4}Earthquakes ${image ~/.conky/weather/API/python_logo.png -p 80,0 -s 15x15}              ${hr 1}$color${color2}${font}${alignc}${color}
########################################### EXECUTE PYTHON SCRIPT
${execi 600 python ~/.conky/earthquakes/earthquakes.py}\
########################################### HEADER
${color2}Mag${GOTO 50}Time${GOTO 120}Lat${GOTO 160}Lon${GOTO 210}Depth(Km)${GOTO 265}Auth${GOTO 310}Region$color
########################################### FEED
${execpi 30 cat $HOME/.conky/earthquakes/eqconky.txt}
${alignc}----------------------------------
${font URW Gothic L:size=7}${color2}${alignc}Types of magnitude${color1}
${GOTO 160}ML: Local magnitude (Richter scale)
${GOTO 160}MW: Moment magnitude
${GOTO 160}Mb: Magnitude of the volume waves
${GOTO 160}Ms: Magnitude of surface waves
${GOTO 160}Md: Duration magnitude
${color4}${hr 1}
]];